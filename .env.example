# Environment variabelen — kopieer naar .env en vul in
# NOOIT .env committen naar git

# Database
DATABASE_URL=postgresql+asyncpg://beleggingsapp:beleggingsapp_dev@localhost:5432/beleggingsapp

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Clerk of Supabase)
AUTH_SECRET=change_me_in_production

# Externe data APIs (fase 2)
# JUSTETF_API_KEY=
# OPENFIGI_API_KEY=

# Ollama — lokale AI runtime
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_TIMEOUT=120
